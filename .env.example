# trading-agent — environment configuration
#
# This agent has no secrets. All configuration is non-sensitive.
# If you integrate a broker API in the future, set those keys through
# the orchestrator dashboard, not here.

# Orchestrator endpoint
ORCHESTRATOR_URL=http://localhost:8000

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Optional: absolute path to a Robinhood CSV export for standalone script usage
# (not needed when the filesystem-agent supplies the file dynamically)
# ROBINHOOD_CSV_PATH=/path/to/robinhood_report.csv
